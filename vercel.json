{
  "rewrites": [
    {
      "source": "/supa-proxy/:match*",
      "destination": "https://lcfzfdjeidinenxcucvj.supabase.co/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/supa-proxy/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS, PATCH, DELETE, POST, PUT" },
        { "key": "Access-Control-Allow-Headers", "value": "X-Client-Info, Authorization, apikey, Content-Type, Accept" }
      ]
    }
  ]
}
